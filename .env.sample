# BaseMouse environment variables
#
# Copy this file to .env for local development, or populate the
# Kubernetes Secret `basemouse-billing` for the live deployment.
# Never commit real secrets to version control.

# Stripe billing
STRIPE_SECRET_KEY=       # server-only restricted key (rk_ preferred; sk_ also works)
STRIPE_WEBHOOK_SECRET=   # endpoint signing secret from Stripe → Webhooks
STRIPE_PRICE_STARTER=    # Stripe recurring Price ID for Starter (e.g. price_...)
STRIPE_PRICE_TEAM=       # Stripe recurring Price ID for Team (e.g. price_...)

# Checkout gate
CHECKOUT_ENABLED=true    # Master switch for self-serve Stripe checkout

# Optional public/common config
STRIPE_PUBLISHABLE_KEY= # public key reserved for future client surfaces
STRIPE_API_VERSION=     # optional; defaults to the app-pinned version
APP_BASE_URL=           # optional; defaults to https://basemouse.com
BILLING_SUCCESS_URL=    # optional explicit Checkout success URL
BILLING_CANCEL_URL=     # optional explicit Checkout cancellation URL
BILLING_CONTACT_URL=    # optional mailto/CRM URL for Enterprise/contact-sales fallback
STRIPE_PRICING_TABLE_ID= # optional public ID reserved for future pricing table embed

# Self-hosted / enterprise licensing (informational; never blocks local/dev)
# Reported in a non-secret form on /healthz. The license key value is held
# server-side only and is never echoed in any response.
BASEMOUSE_LICENSE_KEY=        # optional self-hosted license key (presence reported, value never leaked)
BASEMOUSE_LICENSE_TIER=       # open | starter | team | enterprise (defaults to open)
BASEMOUSE_SELF_HOSTED=        # set to "true" to label this as a self-hosted deployment
BASEMOUSE_LICENSE_EXPIRES_AT= # optional expiry text/date (e.g. 2027-01-01); reported, not enforced

# Hybrid retrieval — local, offline hashed-feature vector signal (no network,
# no external vector DB, no paid embedding API). Only affects retrieval=hybrid.
BASEMOUSE_VECTOR_RETRIEVAL=   # local (default) | off — "off" keeps graph+lexical hybrid
BASEMOUSE_VECTOR_DIMENSIONS=  # embedding dimensions, 8-1024 (defaults to 64)

# MeshAI governance hook (OpenTelemetry OTLP/HTTP) — disabled until both are set
MESHAI_OTLP_ENDPOINT=    # e.g. https://api.meshai.dev/api/v1/ingest (no-op if unset)
MESHAI_API_KEY=          # server-only MeshAI ingest key (never serialized to the browser)
MESHAI_SERVICE_NAME=     # optional service.name override (defaults to basemouse)
MESHAI_OTLP_TIMEOUT_MS=  # optional emit timeout in ms (defaults to 3000)
