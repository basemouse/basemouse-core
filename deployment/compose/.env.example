# BaseMouse service
# Image to run. Defaults to the published GHCR image when unset, so you can
# `docker compose pull && docker compose up -d` with no local build. Set this to
# a local tag (e.g. basemouse-local:latest) and run `docker compose up --build`
# to build from source instead.
BASEMOUSE_IMAGE=ghcr.io/basemouse/basemouse:latest
BASEMOUSE_PORT=3000
HOST=0.0.0.0
PORT=3000
# Optional durable Postgres store. Leave unset for in-memory/dev seed mode.
# DATABASE_URL=postgres://basemouse:basemouse@postgres:5432/basemouse
# DATABASE_CA_CERT=/path/to/ca.pem

# Self-hosted/internal deployment hints (documented for operators; not all are app-enforced yet)
BASEMOUSE_INTERNAL=true
ALLOWED_ORIGINS=http://localhost:3000,http://basemouse.internal:3000
BASEMOUSE_TOKEN=bm_replace_with_workspace_key

# Self-hosted / enterprise licensing (informational; reported on /healthz, never blocks)
# The license key value is server-only and is never echoed in any response.
# BASEMOUSE_LICENSE_KEY=bml_replace_with_license_key
BASEMOUSE_LICENSE_TIER=open
BASEMOUSE_SELF_HOSTED=true
# BASEMOUSE_LICENSE_EXPIRES_AT=2027-01-01

# Hybrid retrieval — local offline hashed-vector signal (no network / no external
# vector DB / no paid embedding API). Only affects retrieval=hybrid.
BASEMOUSE_VECTOR_RETRIEVAL=local   # local (default) | off
# BASEMOUSE_VECTOR_DIMENSIONS=64   # embedding dimensions, 8-1024 (defaults to 64)

# Optional MeshAI governance hook (OpenTelemetry OTLP/HTTP). No-op until both set.
# MESHAI_OTLP_ENDPOINT=https://api.meshai.dev/api/v1/ingest
# MESHAI_API_KEY=msh_replace_with_ingest_key

# Optional Slack connector profile
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=llama3.2:latest
LLM_API_KEY=local
SYSTEM_PROMPT=You are a helpful technical assistant for the team. Use BaseMouse context and cite sources.
SQLITE_PATH=/app/.data/slack-local-llm.sqlite

# Optional local LLM profile
OLLAMA_PORT=11434
