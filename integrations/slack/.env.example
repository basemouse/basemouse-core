# Slack app tokens (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Local/OpenAI-compatible LLM
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:latest
LLM_API_KEY=local
SYSTEM_PROMPT=You are a helpful technical assistant for the team. Use BaseMouse context and cite sources.

# Stream the answer into Slack via throttled chat.update (true|false).
# Falls back to a single final post if the server or Slack rejects updates.
LLM_STREAM=false
# Minimum seconds between Slack message edits while streaming (avoids rate limits).
STREAM_MIN_INTERVAL_SECONDS=1.2

# BaseMouse context API
BASEMOUSE_URL=http://localhost:3000
BASEMOUSE_TOKEN=bm_your_key_here
BASEMOUSE_LIMIT=5
REQUEST_TIMEOUT_SECONDS=15

# How the bot grounds answers with BaseMouse:
#   always = fetch a context pack for every message (default)
#   auto   = expose a fetch_context_pack tool and let the LLM decide (needs a
#            tool-calling capable model; degrades to a plain answer otherwise)
#   off    = never fetch BaseMouse context
BASEMOUSE_RETRIEVAL_MODE=always

# Emoji reaction added while the bot is thinking, removed when done.
# Requires the reactions:write bot scope. Leave blank to disable.
THINKING_REACTION=hourglass_flat

# Optional persistent thread history/project mapping
SQLITE_PATH=.data/slack-local-llm.sqlite
HISTORY_LIMIT=20
LOG_LEVEL=INFO
